#!/usr/bin/env bash
# Project dispatcher — run common commands from project root.
#
# Usage: ./dev <command> [args...]

set -euo pipefail

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

usage() {
  cat <<'EOF'
Usage: ./dev <command> [args...]

Local commands (run on Mac):
  comfyui [args]            Launch ComfyUI on Mac MPS
  download-weights          Download Phase 0 v1 model weights (~18 GB)
  fal <model> [flags]       Phase 0 v1 paid talking-head test on fal.ai
                            (legacy; aurora/omnihuman/kling — see scripts/fal_call.py)

Phase 0 v2 — local (no GPU needed):
  validate-script <path>    Validate a script JSON against script_schema.json
  init-config               Emit scripts/test_3/mascot/daramzzi/daramzzi_config.yaml
                            from FSD §3.2 defaults
  smoke                     Lint check + schema check + JS syntax sanity
                            (everything that can run without RunPod)
  renderer start            Start R-Solo realtime renderer prototype
                            (HTTP server on :8765 + opens browser)
  renderer stop             Stop the renderer HTTP server

Phase 0 v2 — remote (run inside RunPod via Docker):
  mascot build              Build the make_mascot docker image
  mascot stage <stage>      Run one stage of pipeline.py
                            (brief|seed|lora-dataset|lora-train|sprites|alpha|normalize|pack|status)
  mascot run-all [--start S]  Run all stages from --start onward
  prototype build           Build the prototype docker image
  prototype voice-ref       One-time CosyVoice 2 voice reference for Daramzzi
  prototype render <clip>   Run full TTS → phoneme → render → encode pipeline
  prototype validate <clip> Schema-validate a clip script

Phase 0 v2 — Kontext Dev test (alternative to PuLID for identity variants):
  kontext bootstrap         git push + SSH pod + run bootstrap_kontext.sh
  kontext smoke             SSH pod + run generate_kontext.py --limit 1 (1 image)
  kontext run [args]        SSH pod + run generate_kontext.py (full 25-image batch)
  kontext pull              rsync outputs/kontext_test/ from RunPod to local

RunPod helpers:
  runpod push               git push, then ssh runpod 'git pull' (assumes ~/.ssh/config alias 'runpod')
  runpod pull-artifacts     rsync atlas/, prototype_runs/ from RunPod to local
  runpod ssh                Open an SSH session to the runpod alias

  help                      Show this help

Examples:
  ./dev validate-script scripts/test_3/scripts/clip_01.json
  ./dev init-config
  ./dev mascot build
  ./dev mascot stage seed
  ./dev mascot run-all --start lora-dataset
  ./dev prototype render scripts/test_3/scripts/clip_01.json
EOF
}

MASCOT_DIR="$PROJECT_ROOT/scripts/test_3/mascot/daramzzi"
PROTOTYPE_DIR="$PROJECT_ROOT/scripts/test_3/prototype"
RUNPOD_ALIAS="${RUNPOD_SSH_ALIAS:-runpod}"
RUNPOD_REMOTE="${RUNPOD_REMOTE_DIR:-/workspace/live_ai_host}"

cmd="${1:-help}"
shift || true

case "$cmd" in
  comfyui)
    exec "$PROJECT_ROOT/scripts/comfyui.sh" "$@"
    ;;
  download-weights)
    exec "$PROJECT_ROOT/scripts/download_weights.sh" "$@"
    ;;
  fal)
    exec uv run --project "$PROJECT_ROOT" python "$PROJECT_ROOT/scripts/fal_call.py" "$@"
    ;;

  validate-script)
    script="${1:?usage: ./dev validate-script <path-to-script.json>}"
    exec uv run --with jsonschema --project "$PROJECT_ROOT" python -c "
import json, sys
from pathlib import Path
import jsonschema
schema = json.loads(Path('scripts/test_3/script_schema.json').read_text())
script = json.loads(Path('$script').read_text())
jsonschema.validate(script, schema)
print('OK: $script validates against script_schema.json')
print('  title:', script.get('title'))
print('  segments:', len(script.get('segments', [])))
"
    ;;

  init-config)
    exec uv run --project "$PROJECT_ROOT" python "$MASCOT_DIR/pipeline.py" init \
      --output "$MASCOT_DIR/daramzzi_config.yaml" "$@"
    ;;

  smoke)
    # Local-only sanity: schema check + JS syntax + Python compile.
    echo "[smoke] validating clip_01.json..."
    "$0" validate-script scripts/test_3/scripts/clip_01.json
    echo "[smoke] python -m compileall on test_3 sources..."
    uv run --project "$PROJECT_ROOT" python -m compileall -q \
      "$MASCOT_DIR" "$PROTOTYPE_DIR" || true
    echo "[smoke] node --check on renderer JS..."
    for f in "$PROJECT_ROOT"/scripts/test_3/renderer/*.js; do
      node --check "$f" || echo "    fail: $f"
    done
    echo "[smoke] done"
    ;;

  renderer)
    # R-Solo realtime renderer prototype — pure local, no GPU dependency.
    # Assets must already exist at scripts/test_3/renderer_realtime/assets/
    #   (talking.mp4, idle.png, voice.wav) — see docs/phase_0_v2/realtime_interaction_plan.md
    sub="${1:-start}"
    shift || true
    RENDERER_DIR="$PROJECT_ROOT/scripts/test_3/renderer_realtime"
    PORT=8765
    case "$sub" in
      start)
        if [ ! -f "$RENDERER_DIR/assets/talking.mp4" ]; then
          echo "ERROR: $RENDERER_DIR/assets/talking.mp4 missing." >&2
          echo "       Generate via EchoMimic v3 first (see realtime_interaction_plan.md §3)." >&2
          exit 1
        fi
        EXISTING=$(lsof -ti :$PORT 2>/dev/null || true)
        if [ -n "$EXISTING" ]; then
          echo "killing existing process on :$PORT (pid=$EXISTING)"
          kill -9 $EXISTING 2>/dev/null || true
          sleep 0.5
        fi
        cd "$RENDERER_DIR"
        nohup python3 -m http.server $PORT --bind 127.0.0.1 > /tmp/renderer_http.log 2>&1 &
        HTTP_PID=$!
        echo "http.server pid=$HTTP_PID port=$PORT (log: /tmp/renderer_http.log)"
        sleep 0.5
        URL="http://127.0.0.1:$PORT/"
        echo "opening $URL"
        open "$URL"
        ;;
      stop)
        EXISTING=$(lsof -ti :$PORT 2>/dev/null || true)
        if [ -n "$EXISTING" ]; then
          kill -9 $EXISTING
          echo "killed renderer http.server (pid=$EXISTING)"
        else
          echo "no renderer running on :$PORT"
        fi
        ;;
      *)
        echo "renderer subcommand: start | stop" >&2
        exit 1
        ;;
    esac
    ;;

  mascot)
    sub="${1:-help}"
    shift || true
    case "$sub" in
      build)
        cd "$MASCOT_DIR" && exec docker build -t daramzzi-pipeline -f Dockerfile .
        ;;
      stage)
        stage_name="${1:?usage: ./dev mascot stage <brief|seed|lora-dataset|lora-train|sprites|alpha|normalize|pack|status>}"
        shift
        cd "$MASCOT_DIR" && exec docker run --rm --gpus all -v "$MASCOT_DIR:/work" daramzzi-pipeline \
          python pipeline.py "$stage_name" "$@"
        ;;
      run-all)
        cd "$MASCOT_DIR" && exec docker run --rm --gpus all -v "$MASCOT_DIR:/work" daramzzi-pipeline \
          python pipeline.py run-all "$@"
        ;;
      *)
        echo "mascot subcommand: build | stage <name> | run-all [--start S]" >&2
        exit 1
        ;;
    esac
    ;;

  prototype)
    sub="${1:-help}"
    shift || true
    case "$sub" in
      build)
        cd "$PROTOTYPE_DIR" && exec docker build -t daramzzi-prototype -f Dockerfile .
        ;;
      voice-ref)
        cd "$PROJECT_ROOT/scripts/test_3" && exec docker run --rm --gpus all \
          -v "$PROJECT_ROOT/scripts/test_3:/work" daramzzi-prototype \
          python prototype/prototype.py voice-ref \
            --output voice/daramzzi_ref.wav "$@"
        ;;
      validate)
        script="${1:?usage: ./dev prototype validate <script.json>}"
        exec "$0" validate-script "$script"
        ;;
      render)
        script="${1:?usage: ./dev prototype render <script.json>}"
        shift || true
        clip_name="$(basename "$script" .json)"
        cd "$PROJECT_ROOT/scripts/test_3" && exec docker run --rm --gpus all \
          -v "$PROJECT_ROOT/scripts/test_3:/work" daramzzi-prototype \
          python prototype/prototype.py render \
            --script "$script" \
            --atlas mascot/daramzzi/atlas/ \
            --voice voice/daramzzi_ref.wav \
            --output-dir "prototype_runs/$clip_name/" \
            "$@"
        ;;
      *)
        echo "prototype subcommand: build | voice-ref | validate <script> | render <script>" >&2
        exit 1
        ;;
    esac
    ;;

  kontext)
    # Flux Kontext Dev identity-variant test — alternative to PuLID stage 2.
    # All commands assume ~/.ssh/config has a 'runpod' alias pointing at the active pod.
    sub="${1:-help}"
    shift || true
    case "$sub" in
      bootstrap)
        git -C "$PROJECT_ROOT" push
        ssh "$RUNPOD_ALIAS" "cd $RUNPOD_REMOTE && git pull && bash scripts/runpod/bootstrap_kontext.sh"
        ;;
      smoke)
        ssh "$RUNPOD_ALIAS" "cd $RUNPOD_REMOTE && python scripts/runpod/generate_kontext.py --limit 1"
        ;;
      run)
        ssh "$RUNPOD_ALIAS" "cd $RUNPOD_REMOTE && python scripts/runpod/generate_kontext.py $*"
        ;;
      pull)
        # rsync may not be installed on minimal pod images; fall back to scp -r.
        if ssh "$RUNPOD_ALIAS" 'command -v rsync >/dev/null 2>&1'; then
          rsync -av "$RUNPOD_ALIAS:$RUNPOD_REMOTE/outputs/kontext_test/" \
            "$PROJECT_ROOT/outputs/kontext_test/"
        else
          mkdir -p "$PROJECT_ROOT/outputs/kontext_test"
          scp -r "$RUNPOD_ALIAS:$RUNPOD_REMOTE/outputs/kontext_test/*" \
            "$PROJECT_ROOT/outputs/kontext_test/"
        fi
        ;;
      *)
        echo "kontext subcommand: bootstrap | smoke | run [args] | pull" >&2
        exit 1
        ;;
    esac
    ;;

  runpod)
    sub="${1:-help}"
    shift || true
    case "$sub" in
      push)
        git -C "$PROJECT_ROOT" push
        ssh "$RUNPOD_ALIAS" "cd $RUNPOD_REMOTE && git pull"
        ;;
      pull-artifacts)
        rsync -av "$RUNPOD_ALIAS:$RUNPOD_REMOTE/scripts/test_3/mascot/daramzzi/atlas/" \
          "$PROJECT_ROOT/scripts/test_3/mascot/daramzzi/atlas/"
        rsync -av "$RUNPOD_ALIAS:$RUNPOD_REMOTE/scripts/test_3/prototype_runs/" \
          "$PROJECT_ROOT/scripts/test_3/prototype_runs/"
        ;;
      ssh)
        exec ssh "$RUNPOD_ALIAS" "$@"
        ;;
      *)
        echo "runpod subcommand: push | pull-artifacts | ssh" >&2
        exit 1
        ;;
    esac
    ;;

  help|-h|--help|"")
    usage
    ;;
  *)
    echo "Unknown command: $cmd" >&2
    echo "" >&2
    usage >&2
    exit 1
    ;;
esac
